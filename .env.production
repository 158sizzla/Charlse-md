# Production Environment Variables

# Node environment
NODE_ENV=production

# Bot Configuration
BOT_NAME=WhatsApp Bot
BOT_PREFIX=!

# Logging
LOG_LEVEL=info

# Session settings (for multi-bot setups)
SESSION_NAME=default-session

# Database (optional - for storing sessions)
# DATABASE_URL=mongodb://user:pass@host:port/db

# Webhook (optional - for Twilio alternative)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# Error reporting (optional)
# SENTRY_DSN=
